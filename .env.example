# Webhook secret entered when registering the GitHub App (generate with `openssl rand -hex 32`)
# Required — if empty, the server rejects every POST with 401 (fail-closed)
GITHUB_WEBHOOK_SECRET=

# GitHub App ID (App settings → General → About → App ID)
GITHUB_APP_ID=

# App private key — set exactly one of file path or inline
# Inline: replace PEM newlines with \n to fit one line (for docker-compose env)
GITHUB_APP_PRIVATE_KEY_PATH=
# GITHUB_APP_PRIVATE_KEY=

# delivery ledger SQLite path — defaults to ./ghcord.db
# GHCORD_DB=

# Discord interactions — developer portal → General Information
# If empty, /interactions/discord rejects every request with 401 (fail-closed)
DISCORD_PUBLIC_KEY=
DISCORD_APP_ID=
# Bot tab → Token. Used for command registration (scripts/register_commands.py) + creating channel webhooks
DISCORD_BOT_TOKEN=
# (Optional) guild command registration — instant propagation, for development.
# If omitted, commands register globally (propagation up to 1 hour)
# DISCORD_GUILD_ID=

# /github signin OAuth — find the Client ID under App settings → General,
# then generate a client secret. Register https://<host>/oauth/github/callback as the Callback URL.
# If empty, the signin command responds with setup instructions.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
